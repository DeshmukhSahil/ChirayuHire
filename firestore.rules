rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Auth helpers
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isOrgMember(orgId) {
      return isSignedIn() && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.orgId == orgId;
    }

    function isOrgAdmin(orgId) {
       let user = get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
       return isSignedIn() && user.orgId == orgId && user.role == 'super-admin';
    }

    function isRecruiter(orgId) {
       let user = get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
       return isSignedIn() && user.orgId == orgId && (user.role == 'recruiter' || user.role == 'super-admin');
    }

    function isValidId(id) {
       return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    // Entities
    match /users/{userId} {
      allow read: if isSignedIn();
      allow create: if isOwner(userId);
      allow update: if isOwner(userId) && (!request.resource.data.diff(resource.data).affectedKeys().hasAny(['role']));
    }

    match /organizations/{orgId} {
      allow read: if isOrgMember(orgId);
      allow update: if isOrgAdmin(orgId);
    }

    match /jobs/{jobId} {
      allow read: if isSignedIn();
      allow create: if isRecruiter(request.resource.data.orgId);
      allow update: if isRecruiter(resource.data.orgId);
      allow delete: if isOrgAdmin(resource.data.orgId);
    }

    match /applications/{applicationId} {
      allow read: if isRecruiter(resource.data.orgId) || isOwner(resource.data.candidateId);
      allow create: if isSignedIn(); // Candidates can apply
      allow update: if isRecruiter(resource.data.orgId);
    }

    match /candidateProfiles/{profileId} {
      allow read: if isOwner(resource.data.userId) || isRecruiter(resource.data.orgId);
      allow write: if isOwner(resource.data.userId);
    }
  }
}
